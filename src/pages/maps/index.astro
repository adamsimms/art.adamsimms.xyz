---
import Base from '../../layouts/Base.astro';

const description =
	"Satellite map of Pinchard's Island, Newfoundland — cabin landmark and Bonavista Bay context.";
const token = import.meta.env.PUBLIC_MAPBOX_TOKEN || '';
const cabin = { lat: 49.2025694, lon: -53.48586388888953 };
const view = { lat: 49.1998, lon: -53.4865, zoom: 13.5 };
---

<Base title="Maps" description={description}>
	<article class="maps-page">
		<header class="page-header">
			<h1>Maps</h1>
			<p class="maps-lede">{description}</p>
			<nav class="maps-subnav" aria-label="Map sections">
				<a href="/maps" aria-current="page">Satellite</a>
				<a href="/maps/trees">53 Trees</a>
				<a href="/maps/resettled">Resettled</a>
				<a href="/cloudberry/archive/">Cloudberry archive</a>
			</nav>
		</header>

		{
			token.startsWith('pk.') ? (
				<div class="maps-shell">
					<div id="pinchard-satellite-map" class="maps-canvas" role="img" aria-label={description} />
				</div>
			) : (
				<p class="maps-missing">
					Map unavailable. Set <code>PUBLIC_MAPBOX_TOKEN</code> (Mapbox public <code>pk.*</code> token)
					and allowlist <code>art.adamsimms.xyz</code> on the token.
				</p>
			)
		}
	</article>
</Base>

{
	token.startsWith('pk.') && (
		<>
			<link href="https://api.mapbox.com/mapbox-gl-js/v3.9.2/mapbox-gl.css" rel="stylesheet" />
			<script is:inline define:vars={{ token, cabin, view }}>
				const boot = () => {
					const script = document.createElement('script');
					script.src = 'https://api.mapbox.com/mapbox-gl-js/v3.9.2/mapbox-gl.js';
					script.onload = () => {
						mapboxgl.accessToken = token;
						const map = new mapboxgl.Map({
							container: 'pinchard-satellite-map',
							style: 'mapbox://styles/mapbox/standard-satellite',
							center: [view.lon, view.lat],
							zoom: view.zoom,
						});
						map.addControl(new mapboxgl.NavigationControl({ visualizePitch: true }), 'top-right');
						new mapboxgl.Marker().setLngLat([cabin.lon, cabin.lat]).addTo(map);
					};
					document.head.appendChild(script);
				};
				if (document.readyState === 'loading') {
					document.addEventListener('DOMContentLoaded', boot);
				} else {
					boot();
				}
			</script>
		</>
	)
}

<style>
	.maps-page {
		max-width: 72rem;
		margin: 0 auto;
		padding: 2rem 1.25rem 4rem;
	}
	.maps-lede {
		max-width: 40rem;
		margin: 0.75rem 0 1.25rem;
		opacity: 0.85;
	}
	.maps-subnav {
		display: flex;
		flex-wrap: wrap;
		gap: 0.75rem 1.25rem;
		margin-bottom: 1.5rem;
		font-size: 0.95rem;
	}
	.maps-subnav a[aria-current='page'] {
		font-weight: 600;
		text-decoration: underline;
	}
	.maps-shell {
		border: 1px solid color-mix(in srgb, currentColor 18%, transparent);
		overflow: hidden;
		min-height: 70vh;
	}
	.maps-canvas {
		width: 100%;
		height: 70vh;
		min-height: 24rem;
	}
	.maps-missing {
		padding: 1rem 0;
	}
</style>
