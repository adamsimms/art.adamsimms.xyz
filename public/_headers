# Site-wide security headers (CSP is report-only until soak).
/*
  X-Content-Type-Options: nosniff
  X-Frame-Options: SAMEORIGIN
  Referrer-Policy: strict-origin-when-cross-origin
  Content-Security-Policy-Report-Only: default-src 'self'; base-uri 'self'; object-src 'none'; frame-ancestors 'self'; form-action 'self'; img-src 'self' data: blob: https://media.adamsimms.xyz https://cloudberry-images.adamsimms.xyz https://cloudberry-thumbs.adamsimms.xyz https://*.mapbox.com https://api.mapbox.com https://events.mapbox.com https://i.vimeocdn.com https://*.vimeocdn.com https://*.google.com https://*.googleapis.com https://*.gstatic.com; media-src 'self' https://cloudberry-images.adamsimms.xyz https://cloudberry-thumbs.adamsimms.xyz https://media.adamsimms.xyz https://player.vimeo.com; script-src 'self' 'unsafe-inline' https://api.mapbox.com https://cloud.umami.is; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com https://api.mapbox.com; font-src 'self' data: https://fonts.gstatic.com; connect-src 'self' https://api.mapbox.com https://*.mapbox.com https://events.mapbox.com https://cloudberry-images.adamsimms.xyz https://cloudberry-thumbs.adamsimms.xyz https://media.adamsimms.xyz https://cloud.umami.is; worker-src 'self' blob:; child-src 'self' blob: https://player.vimeo.com https://www.google.com https://www.google.com/maps; frame-src 'self' https://player.vimeo.com https://www.google.com https://www.google.com/maps https://maps.google.com;

# Do not use immutable year-long cache on unhashed archive paths.
# A prior bare Pages deploy soft-404'd missing JS/CSS as homepage HTML; those
# responses were then edge-cached under /cloudberry/archive/js/* forever.
/cloudberry/archive/data/*
  Cache-Control: public, max-age=3600

/cloudberry/archive/css/*
  Cache-Control: public, max-age=3600, must-revalidate

/cloudberry/archive/js/*
  Cache-Control: public, max-age=3600, must-revalidate

/cloudberry/archive/vendor/*
  Cache-Control: public, max-age=86400

/cloudberry/archive/images/*
  Cache-Control: public, max-age=86400

/cloudberry/archive/favicon/*
  Cache-Control: public, max-age=86400
